# Webex Integration credentials (from developer.webex.com -> My Apps)
WEBEX_CLIENT_ID=your_webex_client_id
WEBEX_CLIENT_SECRET=your_webex_client_secret

# Snowflake OAuth credentials
# SNOWFLAKE_CLIENT_ID     -> from: DESC SECURITY INTEGRATION WEBEX_OAUTH
# SNOWFLAKE_CLIENT_SECRET -> from: SELECT SYSTEM$SHOW_OAUTH_CLIENT_SECRETS('WEBEX_OAUTH')
SNOWFLAKE_CLIENT_ID=your_snowflake_client_id
SNOWFLAKE_CLIENT_SECRET=your_snowflake_client_secret
SNOWFLAKE_AUTH_URL=https://<account>.snowflakecomputing.com/oauth/authorize
SNOWFLAKE_TOKEN_URL=https://<account>.snowflakecomputing.com/oauth/token-request

# App settings
PORT=3000
REDIRECT_URI=http://localhost:3000/callback
# APP_BASE_URL: used to build the Snowflake login link sent inside Webex DMs.
# In dev: set to your ngrok URL (e.g. https://abc123.ngrok-free.app)
# In prod: set to your public app URL
APP_BASE_URL=https://<your-ngrok-or-prod-url>

# Webex Bot credentials (from developer.webex.com -> My Apps -> Bot)
WEBEX_BOT_TOKEN=your_webex_bot_token
BOT_ID=your_bot_id   # Person ID from GET /people/me — NOT the Application ID

# Snowflake connection context
# No service account needed — each user authenticates with their own Snowflake credentials.
# These set the default database/schema context for queries.
SNOWFLAKE_ACCOUNT=your_account_identifier   # e.g. lqb16037 (from your .snowflakecomputing.com URL)
SNOWFLAKE_DATABASE=AI_DB
SNOWFLAKE_SCHEMA=PUBLIC

# Cortex model (options: mistral-large2, llama3.1-70b, snowflake-arctic)
CORTEX_MODEL=mistral-large2
